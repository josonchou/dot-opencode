{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "rules/*"],
  "autoupdate": true,
  "agent": {
    "plan": {
      "model": "github-copilot/claude-opus-4.6",
    },
    "build": {
      "model": "opencode-go/deepseek-v4-pro",
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
    },
  },
  "plugin": [
    // "superpowers@git+https://github.com/obra/superpowers.git#latest",
    // "opencode-cmux@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@warp-dot-dev/opencode-warp@0.1.5",
    "oh-my-openagent@latest",
  ],
  "mcp": {
    "feishu-mcp": {
      "type": "remote",
      "url": "${FEISHU_MCP_URL}",
      "enabled": true,
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "mcp-fetch-server"],
      "environment": {
        "DEFAULT_LIMIT": "50000",
      },
      "enabled": false,
    },
    "web-search": {
      "type": "local",
      "command": ["npx", "open-websearch@latest"],
      "environment": {
        "ALLOWED_SEARCH_ENGINES": "bing,juejin,baidu,csdn,brave",
        "DEFAULT_SEARCH_ENGINE": "bing",
        "MODE": "stdio",
      },
      "enabled": false,
    },
    "dart": {
      "type": "local",
      "command": ["dart", "mcp-server", "--force-roots-fallback"],
      "enabled": false,
    },
  },
  // LSP 服务器配置
  "lsp": {
    "json": {
      "command": ["vscode-json-languageserver", "--stdio"],
      "extensions": ["json", "jsonc"],
    },
    "ets-lsp": {
      "command": ["ets-language-server", "--stdio"],
      "extensions": ["ets", ".ets"],
      "initialization": {
        "ets": {
          "sdkPath": "/Applications/DevEco-Studio.app/Contents/sdk/default/openharmony",
          "baseSdkPath": "/Users/joson/harmony-tools/ohos_sdk",
          "hmsPath": "/Applications/DevEco-Studio.app/Contents/sdk/default/hms",
        },
      },
    },
  },
}
