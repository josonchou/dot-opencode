{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "rules/*"],
  "autoupdate": true,
  // "permission": {
  //   // "webfetch": "ask",
  //
  //
  // },

  "agent": {
    "plan": {
      "model": "github-copilot/claude-opus-4.6",
    },
    "build": {
      "model": "kimi-for-coding/k2p5",
      "temperature": 0.3,
    },
    "explore": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.5",
    },
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-cmux",
    // "oh-my-opencode"
  ],
  "mcp": {
    "fetch": {
      "type": "local",
      "command": ["npx", "mcp-fetch-server"],
      "environment": {
        "DEFAULT_LIMIT": "50000",
      },
      "enabled": false,
    },
    "web-search": {
      "type": "local",
      "command": ["npx", "open-websearch@latest"],
      "environment": {
        "ALLOWED_SEARCH_ENGINES": "bing,juejin,baidu,csdn,brave",
        "DEFAULT_SEARCH_ENGINE": "bing",
        "MODE": "stdio",
      },
      "enabled": false,
    },
    // "MiniMax": {
    //   "type": "local",
    //   "command": ["uvx", "minimax-coding-plan-mcp", "-y"],
    //   "enabled": true,
    // },
    "dart": {
      "type": "local",
      "command": ["dart", "mcp-server", "--force-roots-fallback"],
      "enabled": false,
    },
  },
  // LSP 服务器配置
  "lsp": {
    "json": {
      "command": ["vscode-json-languageserver", "--stdio"],
      "extensions": ["json", "jsonc"],
    },
  },
}
