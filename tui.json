{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "martina-dark",
  "keybinds": {
    "app_exit": "<leader>q,ctrl+q",
    "input_clear": "ctrl+c",
    "input_submit": "return,ctrl+y",
    "input_newline": "shift+return,ctrl+return,alt+return,ctrl+j",
    "session_interrupt": "escape,ctrl+c",
    "input_move_left": "left",
    "input_move_right": "right",
    "messages_page_up": "pageup,ctrl+u",
    "messages_page_down": "pagedown,ctrl+d"
  },
  "scroll_acceleration": {
    "enabled": true
  },
  "plugin": [
    [
      "oc-plugin-rainbow",
      {
        "enabled": true,
        "fg": true,
        "bg": true,
        "speed": 0.008,
        "turns": 3,
        "glow": 0.05,
        "keybinds": {
          "logo_splash": "ctrl+shift+r"
        }
      }
    ]
  ]
}
